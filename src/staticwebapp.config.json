{
"navigationFallback": {
    "rewrite": "/index.html"
  },
  "routes": [
    {
        "route": "/erp/admin/*",
        "allowedRoles": [ "admin" ]
    },
    {
      "route": "/countdown/*",
      "allowedRoles": [ "anonymous", "authenticated", "admin", "user" ]
    },
    {
      "route": "/public/*",
      "allowedRoles": [ "anonymous", "authenticated", "admin", "user" ]
    },
    {
      "route": "/erp/*",
      "allowedRoles": [ "admin", "user" ]
    },
    {
      "route": "/logout",
      "redirect": "/.auth/logout"
    },
    {
      "route": "/qr/*",
      "redirect": "/qr/",
      "allowedRoles": [ "admin", "user", "anonymous", "authenticated" ]
    },
    {
      "route": "/qr/qrview/*",
      "redirect": "/qr/qrview/",
      "allowedRoles": [ "admin", "user" ]
    },
    {
      "route": "/*",
      "allowedRoles": [ "admin", "user", "authenticated", "anonymous" ]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=.referrer",
      "statusCode": 302
    }
  }

}