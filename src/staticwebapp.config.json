{
"navigationFallback": {
    "rewrite": "/index.html"
  },
  "routes": [
    {
        "route": "/erp/admin/*",
        "allowedRoles": [ "admin" ],
        "rewrite": "/.auth/login/microsoft?prompt=select_account"
    },
    {
      "route": "/countdown/*",
      "allowedRoles": [ "anonymous", "authenticated", "admin", "user" ]
    },
    {
      "route": "/public/*",
      "allowedRoles": [ "anonymous", "authenticated", "admin", "user" ]
    },
    {
      "route": "/erp/*",
      "allowedRoles": [ "admin", "user" ],
      "rewrite": "/.auth/login/microsoft?prompt=select_account"
    },
    {
      "route": "/*",
      "allowedRoles": [ "admin", "user", "authenticated", "anonymous" ],
      "rewrite": "/.auth/login/microsoft?prompt=select_account"
    }
  ]
}