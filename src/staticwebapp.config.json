{
"navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/*.js", "/*.css", "/*.png", "/*.jpg", "/*.ico"]
  },
  "mimeTypes": {
    ".js": "application/javascript",
    ".css": "text/css",
    ".html": "text/html"
  },
  "routes": [
    {
        "route": "/erp/admin/*",
        "allowedRoles": [ "admin" ]
    },
    {
      "route": "/countdown/*",
      "allowedRoles": [ "anonymous", "authenticated", "admin", "user" ]
    },
    {
      "route": "/public/*",
      "allowedRoles": [ "anonymous", "authenticated", "admin", "user" ]
    },
    {
      "route": "/erp/*",
      "allowedRoles": [ "admin", "user" ]
    },
    {
      "route": "/logout",
      "redirect": "/.auth/logout"
    },
    {
      "route": "/*",
      "allowedRoles": [ "admin", "user", "authenticated", "anonymous" ]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=.referrer",
      "statusCode": 302
    }
  }

}